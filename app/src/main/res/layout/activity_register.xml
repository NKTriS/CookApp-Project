<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#2AD2C1"
    tools:context=".RegisterActivity">

    <!-- Top hero section -->
    <LinearLayout
        android:id="@+id/hero_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingTop="12dp"
        app:layout_constraintHeight_percent="0.32"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="start"
            android:layout_marginStart="24dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_circle_outline"
            android:backgroundTint="#33FFFFFF"
            android:padding="12dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#FFFFFF" />

        <!-- Hat icon -->
        <FrameLayout
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_outline"
            android:backgroundTint="#FFFFFF"
            android:layout_marginBottom="16dp">
            <ImageView
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_nav_recipe"
                app:tint="#2AD2C1" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tham gia Cookapp"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tạo tài khoản để bắt đầu nấu ăn"
            android:textColor="#FFEDD4"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom sheet style card -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_bottom_sheet"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/hero_section">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="32dp"
            android:paddingEnd="24dp"
            android:paddingBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:text="Đăng ký"
                android:textColor="#101828"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- First Name Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Họ và tên"
                android:textColor="#364153"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_box_8e8e93_stroke"
                android:hint="Nguyễn Văn A"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1C1B1F"
                android:textColorHint="#99A1AF"
                android:textSize="16sp" />

            <!-- Email Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Email"
                android:textColor="#364153"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_box_8e8e93_stroke"
                android:hint="email@cua.ban"
                android:inputType="textEmailAddress"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1C1B1F"
                android:textColorHint="#99A1AF"
                android:textSize="16sp" />

            <!-- Password Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Mật khẩu"
                android:textColor="#364153"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_box_8e8e93_stroke"
                android:hint="Tạo mật khẩu"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1C1B1F"
                android:textColorHint="#99A1AF"
                android:textSize="16sp" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ít nhất 8 ký tự"
                android:textColor="#6A7282"
                android:textSize="12sp"
                android:layout_marginBottom="16dp"/>

            <!-- Confirm Password Field -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="Xác nhận mật khẩu"
                android:textColor="#364153"
                android:textSize="14sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/et_confirm_password"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_box_8e8e93_stroke"
                android:hint="Nhập lại mật khẩu"
                android:inputType="textPassword"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textColor="#1C1B1F"
                android:textColorHint="#99A1AF"
                android:textSize="16sp" />

            <!-- Terms -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp"
                android:gravity="top">
                <CheckBox
                    android:id="@+id/cb_terms"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="#2AD2C1" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:layout_marginTop="6dp"
                    android:text="Tôi đồng ý với Điều khoản &amp; Điều kiện và Chính sách bảo mật"
                    android:textColor="#4A5565"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Register Button -->
            <Button
                android:id="@+id/btn_register"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:backgroundTint="#BF0502"
                android:text="Tạo tài khoản"
                android:textColor="#FFFFFF" />

            <!-- Divider -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#D1D5DC" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text=" Hoặc đăng ký với " android:textColor="#6A7282" android:textSize="14sp" />
                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" android:background="#D1D5DC" />
            </LinearLayout>

            <!-- Social Register -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <Button
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Google"
                    android:textColor="#364153"
                    android:layout_marginEnd="6dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp" />

                <Button
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="48dp"
                    android:backgroundTint="#FFFFFF"
                    android:text="Facebook"
                    android:textColor="#364153"
                    android:layout_marginStart="6dp"
                    app:strokeColor="#E5E7EB"
                    app:strokeWidth="1dp" />
            </LinearLayout>

            <!-- Login Link -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đã có tài khoản? "
                    android:textColor="#4A5565" />

                <TextView
                    android:id="@+id/tv_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Đăng nhập"
                    android:textColor="#FF383C"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
