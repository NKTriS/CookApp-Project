<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5"
    tools:context=".OrderDetailActivity">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="36dp"
        android:paddingEnd="16dp"
        android:paddingBottom="14dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical"
        android:elevation="2dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:padding="4dp"
            android:src="@drawable/ic_back_arrow"
            app:tint="#1A1A1A" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Chi tiết đơn hàng"
            android:textColor="#1A1A1A"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:layout_constraintBottom_toTopOf="@id/bottom_bar">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <!-- ① Status stepper card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:id="@+id/tv_detail_order_id"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Đơn #1"
                        android:textColor="#1A1A1A"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chờ xác nhận"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@drawable/bg_pill_ff7043"
                        android:backgroundTint="#FFA726"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp" />
                </LinearLayout>

                <!-- Stepper -->
                <LinearLayout
                    android:id="@+id/ll_stepper"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView android:id="@+id/step_1" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Chờ xác nhận" android:textColor="#FFA726" android:textSize="10sp" android:textStyle="bold" android:gravity="center"/>
                    <View android:id="@+id/line_1_2" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="0.5" android:background="#E0E0E0"/>
                    <TextView android:id="@+id/step_2" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Đang xử lý" android:textColor="#BDBDBD" android:textSize="10sp" android:gravity="center"/>
                    <View android:id="@+id/line_2_3" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="0.5" android:background="#E0E0E0"/>
                    <TextView android:id="@+id/step_3" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Đang giao" android:textColor="#BDBDBD" android:textSize="10sp" android:gravity="center"/>
                    <View android:id="@+id/line_3_4" android:layout_width="0dp" android:layout_height="2dp" android:layout_weight="0.5" android:background="#E0E0E0"/>
                    <TextView android:id="@+id/step_4" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Đã giao" android:textColor="#BDBDBD" android:textSize="10sp" android:gravity="center"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ② Cancelled info (hidden by default) -->
            <LinearLayout
                android:id="@+id/ll_cancel_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin hủy đơn"
                    android:textColor="#FF383C"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Lý do" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_cancel_reason" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="100dp" android:layout_height="wrap_content" android:text="Thời gian hủy" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_cancel_time" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ③ Order details card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thông tin đơn hàng"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="14dp"/>

                <!-- Ngày đặt -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="Ngày đặt" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_date" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Địa chỉ -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="Địa chỉ" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_address" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Thanh toán -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="Thanh toán" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_payment" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Sản phẩm -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="Sản phẩm" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_items" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Ghi chú -->
                <LinearLayout android:id="@+id/ll_note_row" android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp" android:visibility="gone">
                    <TextView android:layout_width="110dp" android:layout_height="wrap_content" android:text="Ghi chú" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_note" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F0F0" android:layout_marginBottom="12dp"/>

                <!-- Tạm tính -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tạm tính" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_subtotal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Phí ship -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginBottom="10dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Phí giao hàng" android:textColor="#8E8E93" android:textSize="13sp"/>
                    <TextView android:id="@+id/tv_detail_shipping" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#1A1A1A" android:textSize="13sp"/>
                </LinearLayout>

                <!-- Tổng cộng -->
                <LinearLayout android:orientation="horizontal" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Tổng thanh toán" android:textColor="#1A1A1A" android:textSize="15sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/tv_detail_total" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="–" android:textColor="#FE2C55" android:textSize="16sp" android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>

            <!-- ④ Refund policy card (shown for cancelled orders) -->
            <LinearLayout
                android:id="@+id/ll_refund_policy"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#FFFFFF"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Chính sách hoàn trả"
                    android:textColor="#1A1A1A"
                    android:textStyle="bold"
                    android:textSize="14sp"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:id="@+id/tv_refund_detail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Đơn hàng thanh toán COD sẽ không phát sinh hoàn trả.\nĐơn hàng Chuyển khoản sẽ được hoàn tiền trong 3–5 ngày làm việc."
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:lineSpacingMultiplier="1.4"/>
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- Bottom bar: Cancel button -->
    <LinearLayout
        android:id="@+id/bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp"
        android:background="#FFFFFF"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:id="@+id/btn_cancel_order"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/bg_box_8e8e93_stroke"
            android:gravity="center"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hủy đơn hàng"
                android:textColor="#FE2C55"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
