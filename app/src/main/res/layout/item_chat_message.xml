<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingStart="12dp"
    android:paddingEnd="12dp"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <!-- Bot message (Left aligned) -->
    <LinearLayout
        android:id="@+id/layout_bot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_bot_avatar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:text="🤖"
            android:textSize="20sp"
            android:gravity="center"
            android:background="@drawable/bg_circle_orange"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_bot_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:background="@drawable/bg_grey_rounded_16"
            android:padding="12dp"
            android:textColor="#333333"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

    <!-- User message (Right aligned) -->
    <LinearLayout
        android:id="@+id/layout_user"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:visibility="gone">

        <TextView
            android:id="@+id/tv_user_message"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="280dp"
            android:background="@drawable/bg_btn_orange_pill"
            android:padding="12dp"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:lineSpacingExtra="3dp" />
    </LinearLayout>

</FrameLayout>
