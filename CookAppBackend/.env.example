# ══════════════════════════════════════════════
# CookApp Backend - Environment Variables
# Copy this file to .env and fill in your values
# ══════════════════════════════════════════════

# Server
PORT=3000
NODE_ENV=development
BASE_URL=http://localhost:3000

# JWT Authentication — PHẢI thay đổi cho production!
JWT_SECRET=your_jwt_secret_here

# AI Services
GEMINI_API_KEY=your_gemini_api_key_here
GROQ_API_KEY=your_groq_api_key_here

# SePay Payment Gateway (sandbox: my.dev.sepay.vn)
SEPAY_API_KEY=your_sepay_api_key_here

# VNPay Sandbox
VNP_TMNCODE=your_vnpay_tmncode_here
VNP_HASHSECRET=your_vnpay_hashsecret_here
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNP_RETURNURL=http://localhost:3000/api/payment/vnpay/return

# Cập nhật